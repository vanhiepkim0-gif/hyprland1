{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 4,

    "modules-left": ["custom/launcher", "custom/claude", "custom/telegram", "custom/translate", "niri/workspaces", "niri/window", "mpris", "custom/cava"],
    "modules-center": ["clock"],
    "modules-right": ["clock#us", "custom/usdvnd", "custom/weather", "custom/recording", "cpu", "memory", "custom/cputemp", "power-profiles-daemon", "backlight", "pulseaudio", "network", "battery", "custom/notification", "tray"],

    "custom/launcher": {
        "format": "َ°€»",
        "tooltip": false,
        "on-click": "wofi --show drun"
    },
    "custom/telegram": {
        "format": "âœˆï¸ڈ",
        "tooltip": false,
        "on-click": "/home/michael/.config/hypr/telegram.sh"
    },
    "custom/claude": {
        "format": "âœ³ï¸ڈ",
        "tooltip": false,
        "on-click": "/home/michael/.config/hypr/claude-cli.sh"
    },
    "custom/translate": {
        "format": "{}",
        "exec": "echo '{\"text\":\"َ°—ٹ\",\"tooltip\":\"Google Dل»‹ch â€” Bل؛¥m: mل»ں popup app (Anhâ†”Viل»‡t) آ· Chuل»™t phل؛£i: dل»‹ch nhanh clipboard\"}'",
        "return-type": "json",
        "interval": "once",
        "on-click": "/home/michael/.config/hypr/gtranslate.sh",
        "on-click-right": "/home/michael/.config/hypr/translate.sh"
    },
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "َ°†چ",
            "2": "َ°ˆ¹",
            "3": "َ°¨‍",
            "4": "َ°‰‹",
            "5": "َ°‌ڑ",
            "6": "َ°‌¦",
            "7": "َ°‌¦",
            "8": "َ°‌¦",
            "9": "َ°چ،",
            "default": "َ°‌¦"
        }
    },
    "niri/window": {
        "max-length": 45,
        "separate-outputs": true,
        "icon": false
    },
    "clock": {
        "format": "َ°¥”  {:%H:%M}",
        "format-alt": "َ°ƒ­  {:%a %d/%m/%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "clock#us": {
        "format": "ًں‡؛ًں‡¸ {:%H:%M}",
        "timezone": "America/New_York",
        "timezones": ["America/New_York", "America/Los_Angeles"],
        "tooltip-format": "Giل»‌ Mل»¹ (cuل»™n ؤ‘ل»ƒ ؤ‘ل»•i ET/PT)\n{:%A, %d/%m/%Y  %H:%M %Z}"
    },
    "custom/cava": {
        "exec": "/home/michael/.config/hypr/cava-waybar.sh",
        "format": "{}",
        "tooltip": false,
        "on-click": "playerctl play-pause"
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} {title}",
        "player-icons": { "default": "ًںژµ", "firefox": "ًںژµ", "chromium": "ًںژµ", "spotify": "ًںژ§" },
        "status-icons": { "paused": "âڈ¸", "playing": "â–¶" },
        "max-length": 28,
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/weather": {
        "exec": "curl -s 'https://wttr.in/?format=%c+%t' 2>/dev/null | sed 's/+//' || echo ''",
        "interval": 1800,
        "tooltip": false
    },
    "custom/usdvnd": {
        "exec": "/home/michael/.config/hypr/usd-vnd.sh",
        "return-type": "json",
        "format": "ًں’µ {}â‚«",
        "interval": 3600,
        "tooltip": true,
        "on-click": "xdg-open 'https://www.google.com/search?q=1+usd+to+vnd'"
    },
    "custom/cputemp": {
        "exec": "/home/michael/.config/hypr/cpu-temp.sh",
        "return-type": "json",
        "format": "َ°”ڈ {}",
        "interval": 5,
        "tooltip": true
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Chل؛؟ ؤ‘ل»™ nguل»“n: {profile}\nBل؛¥m ؤ‘ل»ƒ ؤ‘ل»•i (tiل؛؟t kiل»‡m â†” cأ¢n bل؛±ng â†” hiل»‡u nؤƒng)",
        "tooltip": true,
        "format-icons": {
            "default": "َ°¾…",
            "performance": "َ°“…",
            "balanced": "َ°¾…",
            "power-saver": "َ°Œھ"
        }
    },
    "custom/recording": {
        "exec": "pgrep -x wf-recorder >/dev/null && echo 'َ°‘ٹ REC' || echo ''",
        "interval": 2,
        "tooltip": false,
        "on-click": "/home/michael/.config/hypr/screen-record.sh full"
    },
    "cpu": {
        "format": "َ°کڑ  {usage}%",
        "interval": 2,
        "tooltip": true
    },
    "memory": {
        "format": "َ°چ›  {percentage}%",
        "interval": 2,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G dأ¹ng ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },
    "backlight": {
        "format": "َ°ƒ   {percent}%",
        "scroll-step": 5,
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip-format": "ؤگل»™ sأ،ng {percent}% â€” cuل»™n chuل»™t ؤ‘ل»ƒ chل»‰nh"
    },
    "pulseaudio": {
        "format": "َ°•¾  {volume}%",
        "format-muted": "َ°–پ  tل؛¯t",
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "أ‚m lئ°ل»£ng {volume}% â€” cuل»™n ؤ‘ل»ƒ chل»‰nh, bل؛¥m phل؛£i ؤ‘ل»ƒ tل؛¯t tiل؛؟ng"
    },
    "network": {
        "format-wifi": "َ°–©",
        "format-ethernet": "َ°’چ",
        "format-disconnected": "َ°–ھ",
        "tooltip-format-wifi": "َ°–©  {essid}  ({signalStrength}%)\n{ifname}: {ipaddr}",
        "tooltip-format-ethernet": "َ°’چ  LAN â€” {ifname}: {ipaddr}",
        "tooltip-format-disconnected": "Mل؛¥t mل؛،ng",
        "on-click": "nm-connection-editor"
    },
    "battery": {
        "format": "َ°پ¹  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-full": "َ°پ¹  {capacity}%",
        "states": { "warning": 30, "critical": 15 }
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ°‚›",
            "dnd-none": "َ°‚›",
            "inhibited-notification": "َ°‚ڑ",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°‚›"
        },
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}
